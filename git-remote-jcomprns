#!/usr/bin/env python3
"""Thin shim so git can find an executable literally named
`git-remote-jcomprns` on PATH. All the actual logic lives in rns_git.py;
this just makes it invocable under the name git requires for its remote
helper protocol."""

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from rns_git import remote_helper_main

if __name__ == "__main__":
    remote_helper_main()
